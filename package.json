{
    "name": "playwright",
    "version": "1.0.0",
    "description": "Playwright",
    "main": "index.js",
    "scripts": {
        "install:all": "npm install --registry=https://registry.npmjs.org",
        "install:dev": "npm install --only=dev --registry=https://registry.npmjs.org",
        "install:prod": "npm install --omit=dev --registry=https://registry.npmjs.org",
        "test:new": "npx playwright test --project=chrome --config=playwright.config.ts --grep @new",
        "test:api": "npx playwright test --project=api --config=playwright.config.ts",
        "test:e2e": "npx playwright test --project=e2e --config=playwright.config.ts",
        "prepare": "husky install",
        "format": "prettier --write .",
        "check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
        "lint": "npx eslint ."
    },
    "devDependencies": {
        "@types/mime-types": "3.0.1",
        "@types/node": "26.0.0",
        "eslint": "9.9.0",
        "eslint-config-prettier": "9.1.0",
        "eslint-plugin-playwright": "2.0.0",
        "eslint-plugin-simple-import-sort": "13.0.0",
        "globals": "17.6.0",
        "husky": "9.1.6",
        "prettier": "3.3.3",
        "typescript-eslint": "8.61.1"
    },
    "dependencies": {
        "@faker-js/faker": "8.4.1",
        "@playwright/test": "1.61.0",
        "@reportportal/agent-js-playwright": "5.4.1",
        "ajv": "8.12.0",
        "ajv-formats": "3.0.1",
        "cheerio": "1.0.0-rc.12",
        "date-fns": "4.4.0",
        "dotenv": "16.1.4",
        "exceljs": "4.3.0",
        "genson-js": "0.0.8",
        "html-entities": "2.5.2",
        "http-status-codes": "2.1.4",
        "mime-types": "3.0.2",
        "typescript": "5.8.2"
    }
}
