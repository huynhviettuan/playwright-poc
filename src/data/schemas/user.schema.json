{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["id", "email", "name", "role", "status"],
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^user-[0-9]{3}$"
        },
        "email": {
            "type": "string",
            "format": "email"
        },
        "password": {
            "type": "string",
            "minLength": 8
        },
        "name": {
            "type": "string",
            "minLength": 1
        },
        "role": {
            "type": "string",
            "enum": ["admin", "user", "guest"]
        },
        "status": {
            "type": "string",
            "enum": ["active", "inactive", "suspended"]
        }
    }
}
